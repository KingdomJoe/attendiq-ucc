<?xml version="1.0" encoding="UTF-8"?>



<?import javafx.scene.control.*?>

<?import javafx.scene.layout.*?>

<?import javafx.scene.chart.*?>



<HBox xmlns="http://javafx.com/javafx"

      xmlns:fx="http://javafx.com/fxml"

      fx:controller="com.ucc.attendance.desktop.controller.AnalyticsController"

      prefHeight="700"

      prefWidth="1000"

      style="-fx-background-color: #0f172a;">



    <VBox styleClass="sidebar" spacing="10" HBox.hgrow="NEVER">

        <Label text="AttendIQ" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" />

        <Label text="Lecturer Panel" styleClass="text-subtitle" />

        <Region prefHeight="30" />

        <Button text="Dashboard" onAction="#handleDashboardNav" styleClass="nav-button" />

        <Button text="Courses" onAction="#handleCoursesNav" styleClass="nav-button" />

        <Button text="Analytics" styleClass="nav-button, nav-button-active" />

        <Region VBox.vgrow="ALWAYS" />

        <Label fx:id="lecturerLabel" text="Dr. Lecturer" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1;" />

        <Button text="Logout" onAction="#handleLogout" styleClass="nav-button" style="-fx-text-fill: #ef4444;" />

    </VBox>



    <VBox HBox.hgrow="ALWAYS" spacing="20" styleClass="content-pane">

        <HBox alignment="CENTER_LEFT" spacing="12">

            <VBox spacing="5" HBox.hgrow="ALWAYS">

                <Label text="Attendance Analytics" styleClass="text-title" />

                <Label text="Performance metrics across your assigned courses. Data refreshes every 30 seconds." styleClass="text-subtitle" />

            </VBox>

            <Button fx:id="refreshButton" text="Refresh Now" styleClass="btn, btn-secondary" />

        </HBox>



        <VBox styleClass="card" spacing="12" VBox.vgrow="ALWAYS">

            <HBox alignment="CENTER_LEFT" spacing="10">

                <Label text="Average Attendance Rate" styleClass="card-title" />

                <Label fx:id="chartSubtitleLabel" text="All courses" styleClass="text-subtitle" />

            </HBox>

            <FlowPane fx:id="courseFilterBar" hgap="8" vgap="8" />

            <BarChart fx:id="attendanceChart" legendVisible="false" prefHeight="280" VBox.vgrow="ALWAYS" styleClass="analytics-chart">

                <xAxis>

                    <CategoryAxis label="Courses" fx:id="courseAxis" />

                </xAxis>

                <yAxis>

                    <NumberAxis label="Rate (%)" lowerBound="0" upperBound="100" tickUnit="10" autoRanging="false" fx:id="rateAxis" />

                </yAxis>

            </BarChart>

        </VBox>



        <VBox styleClass="card" spacing="10" prefHeight="240">

            <Label text="Course Breakdown Metrics" styleClass="card-title" />

            <TableView fx:id="metricsTable" VBox.vgrow="ALWAYS" styleClass="structured-table">

                <columns>

                    <TableColumn fx:id="codeCol" text="Course Code" prefWidth="110" minWidth="90" />

                    <TableColumn fx:id="nameCol" text="Course Name" prefWidth="220" minWidth="140" />

                    <TableColumn fx:id="sessionsHeldCol" text="Sessions Held" prefWidth="110" minWidth="90" />

                    <TableColumn fx:id="totalPresentCol" text="Total Present" prefWidth="110" minWidth="90" />

                    <TableColumn fx:id="avgRateCol" text="Avg Rate" prefWidth="100" minWidth="80" />

                </columns>

            </TableView>

        </VBox>

    </VBox>

</HBox>

