<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ucc.attendance.desktop.controller.StudentHistoryController"
      prefHeight="700"
      prefWidth="1000"
      style="-fx-background-color: #0f172a;">

    <VBox styleClass="sidebar" prefWidth="240" spacing="10">
        <Label text="AttendIQ" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" />
        <Label text="Student Portal" styleClass="text-subtitle" />
        <Region prefHeight="30" />
        <Button text="Dashboard" onAction="#handleDashboardNav" styleClass="nav-button" />
        <Button text="Attendance History" styleClass="nav-button, nav-button-active" />
        <Button text="Profile" onAction="#handleProfile" styleClass="nav-button" />
        <Region VBox.vgrow="ALWAYS" />
        <Label fx:id="studentNameLabel" text="Student Name" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1;" />
        <Label fx:id="studentIndexLabel" text="UCC/CS/001" styleClass="text-subtitle" style="-fx-font-size: 11px;" />
        <Button text="Logout" onAction="#handleLogout" styleClass="nav-button" style="-fx-text-fill: #ef4444;" />
    </VBox>

    <VBox spacing="20" style="-fx-padding: 30;" HBox.hgrow="ALWAYS">
        <VBox spacing="5">
            <Label text="Attendance History" styleClass="text-title" />
            <Label text="Complete record of your verified attendance scans." styleClass="text-subtitle" />
        </VBox>
        <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
            <Label text="Attendance History" styleClass="card-title" />
            <TextField fx:id="searchHistoryField" promptText="Search by course code, name, or status…" />
            <TableView fx:id="historyTable" VBox.vgrow="ALWAYS" styleClass="structured-table">
                <columns>
                    <TableColumn fx:id="courseCodeCol" text="Course Code" prefWidth="150" />
                    <TableColumn fx:id="courseNameCol" text="Course Name" prefWidth="350" />
                    <TableColumn fx:id="timeCol" text="Attendance Time" prefWidth="200" />
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="120" />
                </columns>
            </TableView>
        </VBox>
    </VBox>
</HBox>
