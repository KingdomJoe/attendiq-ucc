<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ucc.attendance.desktop.controller.ProfileController"
      spacing="20"
      styleClass="content-pane"
      prefWidth="480">

    <Label text="Edit Profile" styleClass="text-title" />
    <Label fx:id="accountLabel" text="Signed in as" styleClass="text-subtitle" wrapText="true" />

    <VBox styleClass="card" spacing="12">
        <VBox spacing="6">
            <Label text="Display name" styleClass="text-subtitle" />
            <TextField fx:id="nameField" promptText="Your name" />
        </VBox>
        <VBox spacing="6">
            <Label text="Current password" styleClass="text-subtitle" />
            <PasswordField fx:id="currentPasswordField" promptText="Required only when changing password" />
        </VBox>
        <VBox spacing="6">
            <Label text="New password" styleClass="text-subtitle" />
            <PasswordField fx:id="newPasswordField" promptText="Leave blank to keep current password" />
        </VBox>
        <HBox spacing="10">
            <Button text="Save changes" onAction="#handleSave" styleClass="btn, btn-primary" />
            <Button text="Cancel" onAction="#handleCancel" styleClass="btn" />
        </HBox>
    </VBox>
</VBox>
