<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ucc.attendance.desktop.controller.DashboardController"
      prefHeight="700"
      prefWidth="1000"
      style="-fx-background-color: #0f172a;">

    <VBox styleClass="sidebar" spacing="10" HBox.hgrow="NEVER">
        <Label text="AttendIQ" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" />
        <Label text="Lecturer Panel" styleClass="text-subtitle" />
        <Region prefHeight="30" />
        <Button text="Dashboard" styleClass="nav-button, nav-button-active" />
        <Button text="Courses" onAction="#handleCoursesNav" styleClass="nav-button" />
        <Button text="Analytics" onAction="#handleAnalyticsNav" styleClass="nav-button" />
        <Region VBox.vgrow="ALWAYS" />
        <Label fx:id="lecturerLabel" text="Dr. Lecturer" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1;" />
        <Button text="Logout" onAction="#handleLogout" styleClass="nav-button" style="-fx-text-fill: #ef4444;" />
    </VBox>

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" styleClass="content-scroll">
        <VBox spacing="20" styleClass="content-pane">
            <VBox spacing="5">
                <Label fx:id="welcomeLabel" text="Welcome" styleClass="text-title" />
                <Label text="Start sessions and monitor live attendance." styleClass="text-subtitle" />
            </VBox>

            <HBox spacing="15">
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Enrolled Students" styleClass="text-subtitle" />
                    <Label fx:id="totalStudentsLabel" text="0" styleClass="text-card-val" />
                </VBox>
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Active Sessions" styleClass="text-subtitle" />
                    <Label fx:id="activeSessionsLabel" text="0" styleClass="text-card-val" />
                </VBox>
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Avg Attendance" styleClass="text-subtitle" />
                    <Label fx:id="avgAttendanceLabel" text="0%" styleClass="text-card-val" />
                </VBox>
            </HBox>

            <VBox fx:id="activeSessionCard" styleClass="card" spacing="10" visible="false" managed="false">
                <Label text="Active Session" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <Label fx:id="activeSessionCourseLabel" text="Course" />
                <HBox spacing="10">
                    <Button text="Open Session" onAction="#handleOpenActiveSession" styleClass="btn, btn-primary" />
                    <Button text="Close Session" onAction="#handleCloseActiveSession" styleClass="btn, btn-secondary" />
                </HBox>
            </VBox>

            <VBox styleClass="card" spacing="15">
                <Label text="Start New Session" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <HBox spacing="10">
                    <ComboBox fx:id="courseComboBox" promptText="Select course" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                    <ComboBox fx:id="sessionTypeComboBox" promptText="Session type" prefWidth="140" />
                    <Button fx:id="startSessionButton" text="Start Session" onAction="#handleStartSession" styleClass="btn, btn-primary" />
                </HBox>
            </VBox>

            <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
                <Label text="Recent Sessions" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                <TableView fx:id="sessionsTable" prefHeight="280" minHeight="200" styleClass="structured-table sessions-table">
                    <columns>
                        <TableColumn fx:id="courseCodeCol" text="Code" prefWidth="72" minWidth="68" maxWidth="90" />
                        <TableColumn fx:id="courseNameCol" text="Course" prefWidth="160" minWidth="120" />
                        <TableColumn fx:id="dateCol" text="Date" prefWidth="128" minWidth="118" />
                        <TableColumn fx:id="typeCol" text="Type" prefWidth="72" minWidth="64" maxWidth="88" />
                        <TableColumn fx:id="presentCol" text="Present" prefWidth="64" minWidth="56" maxWidth="72" />
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="76" minWidth="68" maxWidth="88" />
                        <TableColumn fx:id="exportCol" text="CSV" prefWidth="92" minWidth="92" maxWidth="92" resizable="false" sortable="false" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>
</HBox>
