<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ucc.attendance.desktop.controller.StudentDashboardController"
      prefHeight="700"
      prefWidth="1000"
      style="-fx-background-color: #0f172a;">

    <VBox styleClass="sidebar" prefWidth="240" spacing="10">
        <Label text="AttendIQ" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #38bdf8;" />
        <Label text="Student Portal" styleClass="text-subtitle" />
        <Region prefHeight="30" />
        <Button text="Dashboard" styleClass="nav-button, nav-button-active" />
        <Button text="Attendance History" onAction="#handleHistoryNav" styleClass="nav-button" />
        <Region VBox.vgrow="ALWAYS" />
        <Label fx:id="studentNameLabel" text="Student Name" style="-fx-font-weight: bold; -fx-text-fill: #cbd5e1;" />
        <Label fx:id="studentIndexLabel" text="UCC/CS/001" styleClass="text-subtitle" style="-fx-font-size: 11px;" />
        <Button text="Logout" onAction="#handleLogout" styleClass="nav-button" style="-fx-text-fill: #ef4444;" />
    </VBox>

    <ScrollPane fitToWidth="true" HBox.hgrow="ALWAYS" styleClass="content-scroll">
        <VBox spacing="20" styleClass="content-pane">
            <VBox spacing="5">
                <Label fx:id="welcomeLabel" text="Welcome" styleClass="text-title" />
                <Label text="Your attendance overview and course enrollment." styleClass="text-subtitle" />
            </VBox>

            <HBox spacing="15">
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Total Sessions" styleClass="text-subtitle" />
                    <Label fx:id="totalSessionsLabel" text="0" styleClass="text-card-val" />
                </VBox>
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Attended" styleClass="text-subtitle" />
                    <Label fx:id="attendedLabel" text="0" styleClass="text-card-val" />
                </VBox>
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Missed" styleClass="text-subtitle" />
                    <Label fx:id="missedLabel" text="0" styleClass="text-card-val" />
                </VBox>
                <VBox styleClass="card" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="Attendance Rate" styleClass="text-subtitle" />
                    <Label fx:id="rateLabel" text="0%" styleClass="text-card-val" />
                </VBox>
            </HBox>

            <GridPane hgap="20" vgap="20">
                <columnConstraints>
                    <ColumnConstraints percentWidth="50" />
                    <ColumnConstraints percentWidth="50" />
                </columnConstraints>

                <VBox styleClass="card" spacing="15" GridPane.columnIndex="0" VBox.vgrow="ALWAYS">
                    <Label text="My Enrolled Courses" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                    <ListView fx:id="enrolledCoursesListView" prefHeight="250" styleClass="dark-list" />
                </VBox>

                <VBox styleClass="card" spacing="15" GridPane.columnIndex="1">
                    <Label text="Join a Course" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                    <Label text="Available courses" styleClass="text-subtitle" />
                    <ComboBox fx:id="availableCoursesComboBox" promptText="Choose available course..." maxWidth="Infinity" />
                    <Label text="Or enter course code manually" styleClass="text-subtitle" />
                    <TextField fx:id="manualCodeField" promptText="e.g. CSC302" />
                    <Button fx:id="joinCourseButton" text="Join Course" onAction="#handleJoinCourse" styleClass="btn, btn-primary" maxWidth="Infinity" />
                </VBox>
            </GridPane>
        </VBox>
    </ScrollPane>
</HBox>
