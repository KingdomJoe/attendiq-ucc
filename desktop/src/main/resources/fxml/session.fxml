<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<HBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.ucc.attendance.desktop.controller.SessionController"
      prefHeight="700"
      prefWidth="1000"
      spacing="0"
      style="-fx-background-color: #0f172a;">

    <ScrollPane fitToWidth="true" prefWidth="460" minWidth="380" maxWidth="480"
                styleClass="content-scroll" style="-fx-background-color: #1e293b;">
        <VBox spacing="16" style="-fx-padding: 24; -fx-background-color: #1e293b; -fx-alignment: top-center;">
            <HBox alignment="CENTER_LEFT" spacing="10" maxWidth="Infinity">
                <Button fx:id="backButton" text="Back" styleClass="btn, btn-secondary" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="closeSessionButton" text="End Session" styleClass="btn, btn-danger" />
            </HBox>
            <Label fx:id="courseLabel" text="Course" wrapText="true" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
            <Label fx:id="typeLabel" text="ACTIVE SESSION" styleClass="status-active" />
            <VBox alignment="CENTER" spacing="10" maxWidth="340"
                  style="-fx-background-color: white; -fx-padding: 12; -fx-background-radius: 12;">
                <ImageView fx:id="qrImageView" fitWidth="240" fitHeight="240" preserveRatio="true" />
                <Button fx:id="fullscreenQrButton" text="Full Screen QR" styleClass="btn, btn-primary" maxWidth="Infinity" />
            </VBox>
            <Label fx:id="refreshLabel" text="Refreshing in 5s..." styleClass="text-subtitle" />
            <VBox alignment="CENTER_LEFT" spacing="5" styleClass="card" maxWidth="Infinity">
                <Label text="Manual Session Code" styleClass="text-subtitle" />
                <Label fx:id="manualCodeLabel" text="------" wrapText="true"
                       style="-fx-font-size: 11px; -fx-font-weight: bold;" maxWidth="380" />
            </VBox>
        </VBox>
    </ScrollPane>

    <VBox spacing="20" style="-fx-padding: 30;" HBox.hgrow="ALWAYS">
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label text="Live Attendance" styleClass="text-title" />
            <Label fx:id="attendanceCountLabel" text="0 / 0" styleClass="text-subtitle" />
        </HBox>
        <TableView fx:id="attendanceTable" VBox.vgrow="ALWAYS" styleClass="structured-table">
            <columns>
                <TableColumn fx:id="indexCol" text="Index" prefWidth="150" />
                <TableColumn fx:id="nameCol" text="Name" prefWidth="250" />
                <TableColumn fx:id="timeCol" text="Time" prefWidth="150" />
            </columns>
        </TableView>
    </VBox>
</HBox>
